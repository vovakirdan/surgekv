pragma module;

fn set_ttl(entry: &mut Entry, ttl: uint?, now_ms: int64) -> LeaseUpdate {
    compare ttl {
        Some(value) => {
            let ttl_ms: int64 = (value to int64) * 1000:int64;
            let deadline_ms: int64 = now_ms + ttl_ms;
            entry.lease_ttl = Some(value);
            entry.lease_deadline_ms = Some(deadline_ms);
            return LeaseUpdate { ttl = Some(value), deadline_ms = Some(deadline_ms) };
        }
        nothing => {
            let stored: uint? = nothing;
            let deadline_ms: int64? = nothing;
            entry.lease_ttl = stored;
            entry.lease_deadline_ms = deadline_ms;
            return LeaseUpdate { ttl = nothing, deadline_ms = nothing };
        }
    };
}

fn index_expiry(store: &mut Store, key: &string, deadline_ms: int64?) -> nothing {
    compare deadline_ms {
        Some(value) => {
            store.expiry_index.push(ExpiryRecord { key = key.__clone(), deadline_ms = value });
        }
        nothing => {}
    };
    return nothing;
}

fn apply_own(store: &mut Store, client_id: &string, key: &string, ttl: uint?, now_ms: int64) -> string {
    compare store.entries.get_mut(key) {
        Some(entry) => {
            let sealed: bool = entry.sealed;
            let borrower_count: uint = entry.borrowers.__len();
            if sealed {
                return sealed_line();
            }
            let mut owner_present: bool = false;
            let owned_by_client: bool = compare entry.owner {
                Some(owner_id) => {
                    owner_present = true;
                    ret owner_id == *client_id;
                }
                nothing => false;
            };
            if owned_by_client {
                let update: LeaseUpdate = set_ttl(entry, ttl, now_ms);
                let response: string = ok_ttl(update.ttl);
                @drop entry;
                index_expiry(store, key, update.deadline_ms);
                return response;
            }
            if owner_present {
                return conflict_line();
            }
            if borrower_count != 0:uint {
                return conflict_line();
            }
            entry.owner = Some(client_id.__clone());
            let update: LeaseUpdate = set_ttl(entry, ttl, now_ms);
            let response: string = ok_ttl(update.ttl);
            @drop entry;
            index_expiry(store, key, update.deadline_ms);
            return response;
        }
        nothing => {
            return not_found_line();
        }
    };
}

fn apply_borrow(store: &mut Store, client_id: &string, key: &string, ttl: uint?, now_ms: int64) -> string {
    compare store.entries.get_mut(key) {
        Some(entry) => {
            let owner_present: bool = compare entry.owner {
                Some(_) => true;
                nothing => false;
            };
            if owner_present {
                return owned_line();
            }
            add_borrower(entry, client_id);
            let update: LeaseUpdate = set_ttl(entry, ttl, now_ms);
            let response: string = ok_ttl(update.ttl);
            @drop entry;
            index_expiry(store, key, update.deadline_ms);
            return response;
        }
        nothing => {
            return not_found_line();
        }
    };
}

fn apply_release(store: &mut Store, client_id: &string, key: &string) -> string {
    compare store.entries.get_mut(key) {
        Some(entry) => {
            let owned_by_client: bool = compare entry.owner {
                Some(owner_id) => owner_id == *client_id;
                nothing => false;
            };
            if owned_by_client {
                clear_lease(entry);
                return ok_plain();
            }
            let removed: bool = remove_borrower(entry, client_id);
            if removed {
                if entry.borrowers.__len() == 0:uint {
                    let ttl: uint? = nothing;
                    let deadline_ms: int64? = nothing;
                    entry.lease_ttl = ttl;
                    entry.lease_deadline_ms = deadline_ms;
                }
                return ok_plain();
            }
            return not_holder_line();
        }
        nothing => {
            return not_found_line();
        }
    };
}

fn apply_seal(store: &mut Store, client_id: &string, key: &string) -> string {
    compare store.entries.get_mut(key) {
        Some(entry) => {
            let owned_by_client: bool = compare entry.owner {
                Some(owner_id) => owner_id == *client_id;
                nothing => false;
            };
            let sealed: bool = entry.sealed;
            if !owned_by_client {
                if sealed {
                    return sealed_line();
                }
                return not_holder_line();
            }
            entry.sealed = true;
            clear_lease(entry);
            return ok_plain();
        }
        nothing => {
            return not_found_line();
        }
    };
}

fn apply_disconnect(store: &mut Store, client_id: &string) -> string {
    let keys: string[] = store.entries.keys();
    let mut i: int = 0;
    let length: int = keys.__len() to int;
    while i < length {
        let key_ref = keys[i];
        compare store.entries.get_mut(key_ref) {
            Some(entry) => {
                let owned_by_client: bool = compare entry.owner {
                    Some(owner_id) => owner_id == *client_id;
                    nothing => false;
                };
                if owned_by_client {
                    clear_lease(entry);
                }
                let removed: bool = remove_borrower(entry, client_id);
                if removed {
                    if entry.borrowers.__len() == 0:uint {
                        let owner_missing: bool = compare entry.owner {
                            Some(_) => false;
                            nothing => true;
                        };
                        if owner_missing {
                            let ttl: uint? = nothing;
                            let deadline_ms: int64? = nothing;
                            entry.lease_ttl = ttl;
                            entry.lease_deadline_ms = deadline_ms;
                        }
                    }
                }
            }
            nothing => {}
        };
        i = i + 1;
    }
    return ok_plain();
}
