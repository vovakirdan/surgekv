pragma module;

import stdlib/directives/test;

/// test:
/// NewGetAndStat:
/// let mut store: Store = new();
/// test.eq::<string>(store.apply(&"client-a", proto.New("session:42", "{\"user\":\"alice\"}")), "OK version=1");
/// test.eq::<string>(store.apply(&"client-a", proto.Get("session:42")), "VALUE {\"user\":\"alice\"}");
/// test.eq::<string>(store.apply(&"client-a", proto.Stat("session:42")), "STAT owner=none borrowers=0 ttl=none version=1 sealed=false");
///
/// OwnBlocksOtherWriter:
/// let mut store: Store = new();
/// let _ = store.apply(&"client-a", proto.New("k", "1"));
/// test.eq::<string>(store.apply(&"client-a", proto.Own("k", Some(30:uint))), "OK ttl=30");
/// test.eq::<string>(store.apply(&"client-b", proto.Set("k", "2")), "ERROR LOCKED key is locked");
///
/// BorrowAndWhoAmI:
/// let mut store: Store = new();
/// let _ = store.apply(&"client-a", proto.New("k", "1"));
/// test.eq::<string>(store.apply(&"client-b", proto.Borrow("k", nothing)), "OK");
/// test.eq::<string>(store.apply(&"client-b", proto.WhoAmI()), "CLIENT id=client-b owned=0 borrowed=1");
///
/// SealAndVersionMismatch:
/// let mut store: Store = new();
/// let _ = store.apply(&"client-a", proto.New("k", "1"));
/// test.eq::<string>(store.apply(&"client-a", proto.SetIf("k", "2", 7:uint)), "ERROR VERSION version mismatch: expected 7, got 1");
/// let _ = store.apply(&"client-a", proto.Own("k", nothing));
/// test.eq::<string>(store.apply(&"client-a", proto.Seal("k")), "OK");
/// test.eq::<string>(store.apply(&"client-a", proto.Set("k", "3")), "ERROR SEALED key is sealed");
///
/// DisconnectClearsHolds:
/// let mut store: Store = new();
/// let _ = store.apply(&"client-a", proto.New("k", "1"));
/// let _ = store.apply(&"client-a", proto.Own("k", nothing));
/// let _ = store.apply(&"client-b", proto.New("r", "2"));
/// let _ = store.apply(&"client-a", proto.Borrow("r", nothing));
/// let _ = store.apply(&"client-a", proto.Disconnect());
/// test.eq::<string>(store.apply(&"client-b", proto.WhoAmI()), "CLIENT id=client-b owned=0 borrowed=0");
/// test.eq::<string>(store.apply(&"client-b", proto.Set("k", "9")), "OK version=2");
///
/// KeysAllSorted:
/// let mut store: Store = new();
/// let _ = store.apply(&"client-a", proto.New("user:2", "2"));
/// let _ = store.apply(&"client-a", proto.New("post:1", "1"));
/// let _ = store.apply(&"client-a", proto.New("user:1", "1"));
/// test.eq::<string>(store.apply(&"client-a", proto.Keys(nothing)), "LIST\npost:1\nuser:1\nuser:2\nEND");
///
/// KeysPatternGlob:
/// let mut store: Store = new();
/// let _ = store.apply(&"client-a", proto.New("user:1", "1"));
/// let _ = store.apply(&"client-a", proto.New("user:2", "2"));
/// let _ = store.apply(&"client-a", proto.New("post:1", "3"));
/// test.eq::<string>(store.apply(&"client-a", proto.Keys(Some("user:*"))), "LIST\nuser:1\nuser:2\nEND");
///
/// OwnTtlExpiresOnNextCommand:
/// let mut store: Store = new();
/// test_set_now_ms(&mut store, Some(0:int64));
/// let _ = store.apply(&"client-a", proto.New("k", "1"));
/// test.eq::<string>(store.apply(&"client-a", proto.Own("k", Some(1:uint))), "OK ttl=1");
/// test_set_now_ms(&mut store, Some(1500:int64));
/// test.eq::<string>(store.apply(&"client-b", proto.Set("k", "2")), "OK version=2");
///
/// BorrowTtlExpiresOnNextCommand:
/// let mut store: Store = new();
/// test_set_now_ms(&mut store, Some(0:int64));
/// let _ = store.apply(&"client-a", proto.New("k", "1"));
/// test.eq::<string>(store.apply(&"client-b", proto.Borrow("k", Some(1:uint))), "OK ttl=1");
/// test_set_now_ms(&mut store, Some(1500:int64));
/// test.eq::<string>(store.apply(&"client-b", proto.WhoAmI()), "CLIENT id=client-b owned=0 borrowed=0");
///
/// StatAfterExpiryClearsLease:
/// let mut store: Store = new();
/// test_set_now_ms(&mut store, Some(0:int64));
/// let _ = store.apply(&"client-a", proto.New("k", "1"));
/// let _ = store.apply(&"client-a", proto.Own("k", Some(1:uint)));
/// test_set_now_ms(&mut store, Some(1500:int64));
/// test.eq::<string>(store.apply(&"client-b", proto.Stat("k")), "STAT owner=none borrowers=0 ttl=none version=1 sealed=false");
