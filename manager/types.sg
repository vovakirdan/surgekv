pragma module;

pub tag Apply(string, proto.Command, Channel<string>);
pub tag Expire();
pub tag Holds(string, Channel<state.HoldCount>);
pub tag Keys(string?, Channel<string[]>);

pub type Message = Apply(string, proto.Command, Channel<string>) | Expire() | Holds(string, Channel<state.HoldCount>) | Keys(string?, Channel<string[]>);

@copy
pub type Handle = {
    requests: Channel<Message>,
};
