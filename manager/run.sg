pragma module;

fn stopped_response() -> string {
    return "ERROR INTERNAL state manager stopped";
}

pub async fn run(requests: Channel<Message>) -> nothing {
    let mut store: state.Store = state.new();
    let mut done: bool = false;

    while !done {
        compare requests.recv() {
            Some(msg) => {
                compare msg {
                    Apply(client_id, cmd, reply) => {
                        let response: string = store.apply(&client_id, cmd);
                        reply.send(own response);
                    }
                    Expire() => {
                        store.expire();
                    }
                    Holds(client_id, reply) => {
                        let counts: state.HoldCount = store.hold_count(&client_id);
                        reply.send(own counts);
                    }
                    Keys(pattern, reply) => {
                        let keys: string[] = store.list_keys(pattern);
                        reply.send(own keys);
                    }
                };
            }
            nothing => {
                done = true;
            }
        };
    }

    return nothing;
}

pub fn open(capacity: uint) -> Handle {
    let requests = make_channel::<Message>(capacity);
    return Handle { requests = requests };
}

extern<Handle> {
    pub fn apply(self: &Handle, client_id: &string, cmd: proto.Command) -> string {
        let reply = make_channel::<string>(1:uint);
        let request: Message = Apply(client_id.__clone(), cmd, reply);
        self.requests.send(own request);

        return compare reply.recv() {
            Some(response) => response;
            nothing => stopped_response();
        };
    }

    pub fn stop(self: &Handle) -> nothing {
        self.requests.close();
        return nothing;
    }

    pub fn expire(self: &Handle) -> bool {
        let request: Message = Expire();
        return self.requests.try_send(own request);
    }

    pub fn holds(self: &Handle, client_id: &string) -> state.HoldCount {
        let reply = make_channel::<state.HoldCount>(1:uint);
        let request: Message = Holds(client_id.__clone(), reply);
        self.requests.send(own request);

        return compare reply.recv() {
            Some(counts) => counts;
            nothing => state.HoldCount { owned = 0:uint, borrowed = 0:uint };
        };
    }

    pub fn keys(self: &Handle, pattern: string?) -> string[] {
        let reply = make_channel::<string[]>(1:uint);
        let request: Message = Keys(pattern, reply);
        self.requests.send(own request);

        return compare reply.recv() {
            Some(keys) => keys;
            nothing => [];
        };
    }
}
