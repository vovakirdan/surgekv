pragma module;

import stdlib/directives/test;

/// test:
/// ClientIdsIncrement:
/// let mut next_id: uint = 1:uint;
/// test.eq::<string>(next_client_id(&mut next_id), "client-1");
/// test.eq::<string>(next_client_id(&mut next_id), "client-2");
///
/// TakeNextLineConsumesBuffer:
/// let mut buffer: string = "PING\r\nGET key\n";
/// let line1 = compare take_next_line(&mut buffer) { Some(v) => v; nothing => "missing"; };
/// let line2 = compare take_next_line(&mut buffer) { Some(v) => v; nothing => "missing"; };
/// let line3 = compare take_next_line(&mut buffer) { Some(v) => v; nothing => "none"; };
/// test.eq::<string>(line1, "PING");
/// test.eq::<string>(line2, "GET key");
/// test.eq::<string>(line3, "none");
/// test.eq::<string>(buffer, "");
///
/// ParseErrorFormatting:
/// let bad = compare proto.parse_line(&"BOOM") { Success(_) => "missing"; err => proto.format_parse_error(&err); };
/// test.assert(bad.starts_with("ERROR BAD_CMD"));
///
/// ShardBucketIsStableAndBounded:
/// test.eq::<uint>(shard_bucket_for_key(&"", 8:uint), 0:uint);
/// test.eq::<uint>(shard_bucket_for_key(&"key-42", 8:uint), 4:uint);
/// test.eq::<uint>(shard_bucket_for_key(&"key-43", 8:uint), 5:uint);
/// test.assert(shard_bucket_for_key(&"anything", 0:uint) == 0:uint);
