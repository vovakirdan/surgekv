pragma module;

fn append_line_bytes(out: &mut byte[], line: &string) -> nothing {
    let view = line.bytes();
    let length: int = view.__len() to int;
    let mut i: int = 0;
    while i < length {
        out.push(view[i]);
        i = i + 1;
    }
    out.push(10:byte);
    return nothing;
}

fn line_bytes(line: string) -> byte[] {
    let mut out: byte[] = [];
    out.reserve(line.__len() + 1:uint);
    append_line_bytes(&mut out, &line);
    return out;
}
