pragma module;

fn parse_key_tail(rest: string?, usage: &string) -> Erring<string, Error> {
    compare rest {
        nothing => {
            return string_usage_error(usage);
        }
        Some(raw) => {
            let key: string = raw.trim();
            if key.__len() == 0:uint || key.find(" ") >= 0 {
                return string_usage_error(usage);
            }
            return Success(key);
        }
    };
}

fn parse_get_cmd(rest: string?) -> Erring<Command, Error> {
    compare parse_key_tail(rest, &"GET <key>") {
        Success(key) => {
            return Success(Get(key));
        }
        err => {
            return err;
        }
    };
}

fn parse_del_cmd(rest: string?) -> Erring<Command, Error> {
    compare parse_key_tail(rest, &"DEL <key>") {
        Success(key) => {
