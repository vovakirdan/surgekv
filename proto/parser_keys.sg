fn parse_keys_cmd(rest: string?) -> Erring<Command, Error> {
    compare rest {
        nothing => {
            let pattern: string? = nothing;
            return Success(Keys(pattern));
        }
        Some(pattern) => {
            return Success(Keys(Some(pattern)));
        }
    };
}
