pragma module;

import stdlib/time as time;
import ../../manager as manager;
import ../../proto as proto;
import ../../state as state;

fn elapsed_us(start: time.Duration) -> int64 {
    let now = time.monotonic_now();
    let elapsed = now.sub(start);
    return elapsed.as_micros();
}

fn print_header() -> nothing {
    print("| probe | iterations | total us | ns/op |");
    print("| --- | ---: | ---: | ---: |");
    return nothing;
}

fn print_row(name: &string, iterations: int, total_us: int64) -> nothing {
    let ns_op: int64 = (total_us * (1000):int64) / (iterations to int64);
    print("| " + *name + " | " + (iterations to string) + " | " + (total_us to string) + " | " + (ns_op to string) + " |");
    return nothing;
}

fn seed_store() -> state.Store {
    let mut store = state.new();
    let _ = store.apply(&"client-a", proto.New("key-42", "{\"v\":\"xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\"}"));
    return store;
}

fn bench_direct_get(iterations: int) -> nothing {
    let mut store = seed_store();
    let key: string = "key-42";
    let start = time.monotonic_now();
    let mut total: uint = 0:uint;
    let mut i: int = 0;
    while i < iterations {
        let response: string = store.read_value(&key);
        total = total + response.__len();
        i = i + 1;
    }
    let total_us = elapsed_us(start);
    if total == 0:uint {
        print("impossible");
    }
    print_row(&"direct_store_get", iterations, total_us);
    return nothing;
}

fn bench_direct_set(iterations: int) -> nothing {
    let mut store = seed_store();
    let client_id: string = "client-a";
    let key: string = "key-42";
    let value: string = "{\"v\":\"yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy\"}";
    let start = time.monotonic_now();
    let mut total: uint = 0:uint;
    let mut i: int = 0;
    while i < iterations {
        let response: string = store.write_value(&client_id, &key, value.__clone());
        total = total + response.__len();
        i = i + 1;
    }
    let total_us = elapsed_us(start);
    if total == 0:uint {
        print("impossible");
    }
    print_row(&"direct_store_set", iterations, total_us);
    return nothing;
}

fn bench_apply_get(iterations: int) -> nothing {
    let mut store = seed_store();
    let client_id: string = "client-a";
