@entrypoint
fn main() -> int {
    // Keep this probe tiny: it measures only state code and channel handoff,
    // without sockets, request parsing, or JSON validation.
    let iterations: int = 50000;
    print_header();
    bench_direct_get(iterations);
    bench_direct_set(iterations);
    bench_apply_get(iterations);
    bench_apply_set(iterations);
    let _ = bench_manager_get(iterations).await();
    let _ = bench_manager_set(iterations).await();
    let _ = bench_manager_apply_get(iterations).await();
    let _ = bench_manager_apply_set(iterations).await();
    return 0;
}
