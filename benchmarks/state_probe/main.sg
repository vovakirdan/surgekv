fn bench_apply_set(iterations: int) -> nothing {
    let mut store = seed_store();
    let client_id: string = "client-a";
    let key: string = "key-42";
    let value: string = "{\"v\":\"yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy\"}";
    let start = time.monotonic_now();
    let mut total: uint = 0:uint;
    let mut i: int = 0;
    while i < iterations {
        let response: string = store.apply(&client_id, proto.Set(key.__clone(), value.__clone()));
        total = total + response.__len();
        i = i + 1;
    }
    let total_us = elapsed_us(start);
    if total == 0:uint {
        print("impossible");
    }
    print_row(&"direct_apply_set", iterations, total_us);
    return nothing;
}

async fn bench_manager_get(iterations: int) -> nothing {
    let handle = manager.open(64:uint);
    let requests = handle.requests;
    let state_task = spawn manager.run(requests);
    let reply = make_channel::<string>(1:uint);
    let key: string = "key-42";
    let seed: manager.Message = manager.Apply("client-a", proto.New(key.__clone(), "{\"v\":\"xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\"}"), reply);
    requests.send(own seed);
    let _ = reply.recv();

    let start = time.monotonic_now();
    let mut total: uint = 0:uint;
    let mut i: int = 0;
    while i < iterations {
        let request: manager.Message = manager.GetValue(key.__clone(), reply);
        requests.send(own request);
        let response: string = compare reply.recv() {
            Some(value) => value;
            nothing => "ERROR stopped";
        };
        total = total + response.__len();
        i = i + 1;
    }
    let total_us = elapsed_us(start);
    if total == 0:uint {
        print("impossible");
    }
    print_row(&"manager_get_reused_reply", iterations, total_us);
    requests.close();
    let _ = state_task.await();
    return nothing;
}

