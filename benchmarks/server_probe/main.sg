@entrypoint
fn main() -> int {
    let iterations: int = 20000;
    print_header();
    bench_append_chunk(iterations);
    bench_take_next_line(iterations);
    bench_take_next_line_pipelined(iterations);
    bench_parse_get(iterations);
    bench_cheap_bucket(iterations);
    bench_format_value(iterations);
    bench_line_bytes(iterations);
    bench_line_bytes_to_array(iterations);
    bench_byte_array_push_constant(iterations);
    bench_bytes_view_len(iterations);
    bench_value_line_bytes_manual_string(iterations);
    bench_value_line_bytes_direct(iterations);
    bench_get_pipeline_cheap(iterations);
    bench_get_pipeline_cheap_direct_response(iterations);
    let _ = bench_get_pipeline_manager(iterations).await();
    bench_set_pipeline_cheap(iterations);
    return 0;
}
