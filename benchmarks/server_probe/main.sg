fn bench_set_pipeline(iterations: int) -> nothing {
    let request_bytes: byte[] = line_bytes_copy("SET key-42 {\"v\":\"xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\"}");
    let no_ttl: uint? = nothing;
    let start = time.monotonic_now();
    let mut total: uint = 0:uint;
    let mut i: int = 0;
    while i < iterations {
        let mut buffer: string = "";
        let _ = append_chunk_copy(&mut buffer, &request_bytes);
        compare take_next_line_copy(&mut buffer) {
            Some(line) => {
                compare proto.parse_line(&line) {
                    Success(cmd) => {
                        compare cmd {
                            proto.Set(key, value) => {
                                total = total + key.__len() + value.__len();
                                let digest: hash.Hash64 = hash.stable64_string(&key);
                                compare digest.bucket(8:uint) {
                                    Some(index) => {
                                        total = total + index;
                                    }
                                    nothing => {}
                                };
                                let response: string = proto.format_ok(Some(2:uint), no_ttl);
                                let bytes: byte[] = line_bytes_copy(response);
                                total = total + bytes.__len();
                            }
                            _ => {
                                total = total + 1:uint;
                            }
                        };
                    }
                    _ => {}
                };
            }
            nothing => {}
        };
        i = i + 1;
    }
    let total_us = elapsed_us(start);
    if total == 0:uint {
        print("impossible");
    }
    print_row(&"set_pipeline_no_tcp_no_manager", iterations, total_us);
    return nothing;
}

