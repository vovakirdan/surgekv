fn bench_parse_get(iterations: int) -> nothing {
    let line: string = "GET key-42";
    let start = time.monotonic_now();
    let mut total: uint = 0:uint;
    let mut i: int = 0;
    while i < iterations {
        compare proto.parse_line(&line) {
            Success(cmd) => {
                compare cmd {
                    proto.Get(key) => {
                        total = total + key.__len();
                    }
                    _ => {
                        total = total + 1:uint;
                    }
                };
            }
            _ => {}
        };
        i = i + 1;
    }
    let total_us = elapsed_us(start);
    if total == 0:uint {
        print("impossible");
    }
    print_row(&"parse_get_server", iterations, total_us);
    return nothing;
}

