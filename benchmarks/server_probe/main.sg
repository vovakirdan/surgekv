pragma module;

import stdlib/hash as hash;
import stdlib/time as time;
import ../../proto as proto;

fn elapsed_us(start: time.Duration) -> int64 {
    let now = time.monotonic_now();
    let elapsed = now.sub(start);
    return elapsed.as_micros();
}

fn print_header() -> nothing {
    print("| probe | iterations | total us | ns/op |");
    print("| --- | ---: | ---: | ---: |");
    return nothing;
}

fn print_row(name: &string, iterations: int, total_us: int64) -> nothing {
    let ns_op: int64 = (total_us * (1000):int64) / (iterations to int64);
    print("| " + *name + " | " + (iterations to string) + " | " + (total_us to string) + " | " + (ns_op to string) + " |");
    return nothing;
}

// Copies the server hot-path shape so the probe can stay outside the production
// module. Keep this in sync with server/line.sg when changing line buffering.
fn append_chunk_copy(buffer: &mut string, bytes: &byte[]) -> bool {
    compare string.from_bytes(bytes) {
        Success(text) => {
            *buffer = *buffer + text;
            return true;
        }
        _ => {
            return false;
        }
    };
}

fn take_next_line_copy(buffer: &mut string) -> string? {
    let current: string = buffer.__clone();
    let newline_idx: int = current.find("\n");
    if newline_idx < 0 {
        return nothing;
    }

    let length: int = current.__len() to int;
    let line: string = current[[0..newline_idx]].trim_end();
    if newline_idx + 1 >= length {
        *buffer = "";
    } else {
        *buffer = current[[newline_idx + 1..length]];
    }
    return Some(line);
}

fn append_string_bytes(out: &mut byte[], s: string) -> nothing {
    let view = s.bytes();
    let length: int = view.__len() to int;
    let mut i: int = 0;
    while i < length {
        out.push(view[i]);
        i = i + 1;
    }
    return nothing;
}

fn line_bytes_copy(line: string) -> byte[] {
    let mut out: byte[] = [];
    out.reserve(line.__len() + 1:uint);
    append_string_bytes(&mut out, line);
    out.push(10:byte);
    return out;
}

fn cheap_shard_bucket(key: &string, shard_count: uint) -> uint {
    if shard_count == 0:uint {
        return 0:uint;
    }
    let view = key.bytes();
    let length: int = view.__len() to int;
    let mut bucket: uint = 0:uint;
    let mut i: int = 0;
    while i < length {
        bucket = ((bucket * 131:uint) + ((view[i] to byte) to uint)) % shard_count;
        i = i + 1;
    }
    return bucket;
}

fn bench_append_chunk(iterations: int) -> nothing {
    let bytes: byte[] = line_bytes_copy("GET key-42");
    let start = time.monotonic_now();
    let mut total: uint = 0:uint;
    let mut i: int = 0;
    while i < iterations {
        let mut buffer: string = "";
        if append_chunk_copy(&mut buffer, &bytes) {
            total = total + buffer.__len();
        }
        i = i + 1;
    }
    let total_us = elapsed_us(start);
    if total == 0:uint {
        print("impossible");
    }
    print_row(&"append_chunk_get", iterations, total_us);
    return nothing;
}

fn bench_take_next_line(iterations: int) -> nothing {
    let start = time.monotonic_now();
    let mut total: uint = 0:uint;
    let mut i: int = 0;
    while i < iterations {
        let mut buffer: string = "GET key-42\n";
        compare take_next_line_copy(&mut buffer) {
            Some(line) => {
                total = total + line.__len();
            }
            nothing => {}
        };
        i = i + 1;
    }
    let total_us = elapsed_us(start);
    if total == 0:uint {
        print("impossible");
    }
    print_row(&"take_next_line_single", iterations, total_us);
    return nothing;
}

fn bench_take_next_line_pipelined(iterations: int) -> nothing {
    let start = time.monotonic_now();
    let mut total: uint = 0:uint;
    let mut i: int = 0;
    while i < iterations {
        let mut buffer: string = "GET key-42\nGET key-43\nGET key-44\nGET key-45\n";
        let mut j: int = 0;
        while j < 4 {
            compare take_next_line_copy(&mut buffer) {
                Some(line) => {
                    total = total + line.__len();
                }
                nothing => {}
            };
            j = j + 1;
        }
        i = i + 1;
    }
    let total_us = elapsed_us(start);
    if total == 0:uint {
        print("impossible");
    }
    print_row(&"take_next_line_pipelined4", iterations * 4, total_us);
    return nothing;
}

fn bench_hash_bucket(iterations: int) -> nothing {
    let key: string = "key-42";
    let start = time.monotonic_now();
    let mut total: uint = 0:uint;
    let mut i: int = 0;
    while i < iterations {
        let digest: hash.Hash64 = hash.stable64_string(&key);
        compare digest.bucket(8:uint) {
            Some(index) => {
                total = total + index;
            }
            nothing => {}
        };
        i = i + 1;
    }
    let total_us = elapsed_us(start);
    if total == 0:uint {
        print("impossible");
    }
    print_row(&"hash_stable64_bucket", iterations, total_us);
    return nothing;
}

fn bench_xxh64_bucket(iterations: int) -> nothing {
    let key: string = "key-42";
    let start = time.monotonic_now();
    let mut total: uint = 0:uint;
    let mut i: int = 0;
    while i < iterations {
        let digest: hash.Hash64 = hash.xxh64_string(&key, 0:uint64);
        compare digest.bucket(8:uint) {
            Some(index) => {
                total = total + index;
            }
            nothing => {}
        };
        i = i + 1;
    }
    let total_us = elapsed_us(start);
    if total == 0:uint {
        print("impossible");
    }
    print_row(&"hash_xxh64_bucket", iterations, total_us);
    return nothing;
}

fn bench_cheap_bucket(iterations: int) -> nothing {
    let key: string = "key-42";
    let start = time.monotonic_now();
    let mut total: uint = 0:uint;
    let mut i: int = 0;
    while i < iterations {
        total = total + cheap_shard_bucket(&key, 8:uint);
        i = i + 1;
    }
    let total_us = elapsed_us(start);
    if total == 0:uint {
        print("impossible");
    }
    print_row(&"hash_cheap_bucket", iterations, total_us);
    return nothing;
}

fn bench_line_bytes(iterations: int) -> nothing {
    let response: string = "VALUE {\"v\":\"xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\"}";
    let start = time.monotonic_now();
    let mut total: uint = 0:uint;
    let mut i: int = 0;
    while i < iterations {
        let bytes = line_bytes_copy(response.__clone());
        total = total + bytes.__len();
        i = i + 1;
    }
    let total_us = elapsed_us(start);
    if total == 0:uint {
        print("impossible");
    }
    print_row(&"line_bytes_value_server", iterations, total_us);
    return nothing;
}

fn bench_get_pipeline(iterations: int) -> nothing {
    let request_bytes: byte[] = line_bytes_copy("GET key-42");
    let value: string = "{\"v\":\"xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\"}";
    let start = time.monotonic_now();
    let mut total: uint = 0:uint;
    let mut i: int = 0;
    while i < iterations {
        let mut buffer: string = "";
        let _ = append_chunk_copy(&mut buffer, &request_bytes);
        compare take_next_line_copy(&mut buffer) {
            Some(line) => {
                compare proto.parse_line(&line) {
                    Success(cmd) => {
                        compare cmd {
                            proto.Get(key) => {
                                total = total + key.__len();
                                let digest: hash.Hash64 = hash.stable64_string(&key);
                                compare digest.bucket(8:uint) {
                                    Some(index) => {
                                        total = total + index;
                                    }
                                    nothing => {}
                                };
                                let response: string = proto.format_value(&value);
                                let bytes: byte[] = line_bytes_copy(response);
                                total = total + bytes.__len();
                            }
                            _ => {
                                total = total + 1:uint;
                            }
                        };
                    }
                    _ => {}
                };
            }
            nothing => {}
        };
        i = i + 1;
    }
    let total_us = elapsed_us(start);
    if total == 0:uint {
        print("impossible");
    }
    print_row(&"get_pipeline_no_tcp_no_manager", iterations, total_us);
    return nothing;
}

