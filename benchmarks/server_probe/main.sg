@entrypoint
fn main() -> int {
    let iterations: int = 20000;
    print_header();
    bench_append_chunk(iterations);
    bench_take_next_line(iterations);
    bench_take_next_line_pipelined(iterations);
    bench_hash_bucket(iterations);
    bench_xxh64_bucket(iterations);
    bench_cheap_bucket(iterations);
    bench_line_bytes(iterations);
    bench_get_pipeline(iterations);
    bench_get_pipeline_xxh64(iterations);
    bench_get_pipeline_cheap(iterations);
    bench_set_pipeline(iterations);
    bench_set_pipeline_xxh64(iterations);
    bench_set_pipeline_cheap(iterations);
    return 0;
}
