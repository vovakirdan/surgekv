async fn bench_get_pipeline_manager(iterations: int) -> nothing {
    let handle = manager.open(64:uint);
    let requests = handle.requests;
    let state_task = spawn manager.run(requests);
    let reply = make_channel::<string>(1:uint);
    let seed: manager.Message = manager.Apply(
        "client-a",
        proto.New("key-42", "{\"v\":\"xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\"}"),
        reply
    );
    requests.send(own seed);
    let _ = reply.recv();

    let request_bytes: byte[] = line_bytes_copy("GET key-42");
    let start = time.monotonic_now();
    let mut total: uint = 0:uint;
    let mut i: int = 0;
    while i < iterations {
        let mut buffer: string = "";
        let _ = append_chunk_copy(&mut buffer, &request_bytes);
        compare take_next_line_copy(&mut buffer) {
            Some(line) => {
                compare proto.parse_line(&line) {
                    Success(cmd) => {
                        compare cmd {
                            proto.Get(key) => {
                                total = total + key.__len();
                                total = total + cheap_shard_bucket(&key, 8:uint);
                                let request: manager.Message = manager.GetValue(key, reply);
                                requests.send(own request);
                                let response: string = compare reply.recv() {
                                    Some(value) => value;
                                    nothing => "ERROR stopped";
                                };
                                let bytes: byte[] = line_bytes_copy(response);
                                total = total + bytes.__len();
                            }
                            _ => {
                                total = total + 1:uint;
                            }
                        };
                    }
                    _ => {}
                };
            }
            nothing => {}
        };
        i = i + 1;
    }
    let total_us = elapsed_us(start);
    if total == 0:uint {
        print("impossible");
    }
    print_row(&"get_pipeline_manager_no_tcp", iterations, total_us);
    requests.close();
    let _ = state_task.await();
    return nothing;
}

fn bench_set_pipeline(iterations: int) -> nothing {
    let request_bytes: byte[] = line_bytes_copy("SET key-42 {\"v\":\"xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\"}");
    let no_ttl: uint? = nothing;
    let start = time.monotonic_now();
    let mut total: uint = 0:uint;
    let mut i: int = 0;
    while i < iterations {
        let mut buffer: string = "";
        let _ = append_chunk_copy(&mut buffer, &request_bytes);
        compare take_next_line_copy(&mut buffer) {
            Some(line) => {
                compare proto.parse_line(&line) {
                    Success(cmd) => {
                        compare cmd {
                            proto.Set(key, value) => {
                                total = total + key.__len() + value.__len();
                                let digest: hash.Hash64 = hash.stable64_string(&key);
                                compare digest.bucket(8:uint) {
                                    Some(index) => {
                                        total = total + index;
                                    }
                                    nothing => {}
                                };
                                let response: string = proto.format_ok(Some(2:uint), no_ttl);
                                let bytes: byte[] = line_bytes_copy(response);
                                total = total + bytes.__len();
                            }
                            _ => {
                                total = total + 1:uint;
                            }
                        };
                    }
                    _ => {}
                };
            }
            nothing => {}
        };
        i = i + 1;
    }
    let total_us = elapsed_us(start);
    if total == 0:uint {
        print("impossible");
    }
    print_row(&"set_pipeline_no_tcp_no_manager", iterations, total_us);
    return nothing;
}

